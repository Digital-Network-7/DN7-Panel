# TeaOps Agent configuration
#
# One binary, two roles selected by argv:
#   teaops-agent          -> supervisor (default; self-splits the agent role)
#   teaops-agent agent    -> agent role (collects + reports metrics)
# In normal use you only run the no-arg supervisor.

# Backend base URL (production should use HTTPS; ws/wss is derived from this)
TEAOPS_BACKEND_URL=https://api.teaops.dn7.cn

# Report interval in seconds
TEAOPS_INTERVAL_SECS=3

# Where to persist the agent token after pairing
TEAOPS_TOKEN_FILE=teaops-agent.token

# Optional: provide a token directly to skip the pairing flow
# TEAOPS_AGENT_TOKEN=

# --- Mutual supervision (the two roles guard each other) ---
# Shared runtime dir for pid/heartbeat/lock files.
TEAOPS_RUNTIME_DIR=.
# Seconds without a heartbeat before a peer role is considered dead.
TEAOPS_HEARTBEAT_TIMEOUT_SECS=15
# Supervisor: how often it checks the agent child, and restart backoff.
TEAOPS_SUPERVISE_INTERVAL_SECS=3
TEAOPS_RESTART_BACKOFF_SECS=2

# --- Binary source (self-update; GitHub-first, download service fallback) ---
TEAOPS_REPO=simonsmithmd/Teaops-agent
TEAOPS_DOWNLOAD_URL=https://downloader.teaops.dn7.cn

# Logging
RUST_LOG=info,teaops_agent=info
