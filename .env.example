# DN7 Panel configuration
#
# One binary, two roles selected by argv:
#   dn7-panel          -> supervisor (default; self-splits the agent role)
#   dn7-panel agent    -> agent role (runs the on-box web console)
#
# In normal use you only run the no-arg supervisor.

# --- Local web management console ---
# Serve the on-box web console (set 0/false to disable).
DN7_WEB_ENABLED=1
# Web console TCP port (initial default; user changes persist in <data>/web.json).
DN7_WEB_PORT=1080

# --- Mutual supervision (the two roles guard each other) ---
# Shared runtime dir for pid/heartbeat/lock files (default /var/ops).
DN7_RUNTIME_DIR=.
# Seconds without a heartbeat before a peer role is considered dead.
DN7_HEARTBEAT_TIMEOUT_SECS=15
# Supervisor: how often it checks the agent child, and restart backoff.
DN7_SUPERVISE_INTERVAL_SECS=3
DN7_RESTART_BACKOFF_SECS=2

# --- Self-update (RETAINED but not auto-triggered yet) ---
# Base URL the self-update mechanism would pull new binaries from.
DN7_UPDATE_URL=https://api.teaops.dn7.cn

# Logging
RUST_LOG=info,dn7_panel=info
