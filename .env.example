# DN7 Panel configuration
#
# One binary, two roles selected by argv:
#   dn7-panel          -> supervisor (default; self-splits the panel role)
#   dn7-panel panel    -> panel role (runs the on-box web console)
#
# In normal use you only run the no-arg supervisor.

# --- Local web management console ---
# Web console TCP port (initial default; user changes persist in <data>/web.json
# and take precedence at runtime).
DN7_WEB_PORT=1080

# --- Mutual supervision (the two roles guard each other) ---
# Base/runtime dir for pid/heartbeat/lock files. Defaults to the canonical
# install dir (/var/dn7/panel); override only for special deployments / tests.
DN7_RUNTIME_DIR=.
# Seconds without a heartbeat before a peer role is considered dead.
DN7_HEARTBEAT_TIMEOUT_SECS=15
# Supervisor: how often it checks the panel child, and restart backoff.
DN7_SUPERVISE_INTERVAL_SECS=3
DN7_RESTART_BACKOFF_SECS=2

# --- Self-update ---
# GitHub repo the self-update mechanism resolves releases from.
DN7_GITHUB_REPO=Digital-Network-7/DN7-Panel
# Base URL of the dn7.cn release mirror / API (used for version + changelog).
DN7_SITE_URL=https://dn7.cn

# Logging
RUST_LOG=info,dn7_panel=info
