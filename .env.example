# TeaOps Agent configuration

# Backend base URL (production should use HTTPS; ws/wss is derived from this)
TEAOPS_BACKEND_URL=https://wxapi.dn7.cn

# Report interval in seconds
TEAOPS_INTERVAL_SECS=3

# Where to persist the agent token after pairing
TEAOPS_TOKEN_FILE=teaops-agent.token

# Optional: provide a token directly to skip the pairing flow
# TEAOPS_AGENT_TOKEN=

# --- Supervision (teaops-agentd) ---
# Shared runtime dir for pid/heartbeat/lock files (must match agentd).
TEAOPS_RUNTIME_DIR=.
# Path to the agentd binary, used if the agent should guard agentd back.
TEAOPS_AGENTD_BIN=./teaops-agentd
# Set to 1 to have the agent relaunch agentd if it dies (mutual guarding).
TEAOPS_GUARD_AGENTD=0
# Seconds without a heartbeat before a peer is considered dead.
TEAOPS_HEARTBEAT_TIMEOUT_SECS=15

# Logging
RUST_LOG=info,teaops_agent=info
